{
  "name": "bundle-size-action",
  "version": "0.2.0",
  "description": "A GitHub Action to check and report bundle sizes",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "vite build",
    "lint": "oxlint src tests vite.config.ts vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run --coverage --coverage.reporter=text --coverage.reporter=json-summary --reporter=default --reporter=junit --outputFile.junit=reports/vitest-junit.xml",
    "clean": "rimraf dist"
  },
  "keywords": [
    "github-action",
    "bundle-size",
    "ci"
  ],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "4.1.9",
    "oxlint": "1.73.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vite": "8.1.0",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11 <12"
  },
  "packageManager": "pnpm@11.1.2"
}
