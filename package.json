{
  "name": "bundle-size-action",
  "version": "0.1.0",
  "description": "A GitHub Action to check and report bundle sizes",
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm run compile && pnpm run bundle",
    "compile": "tsc",
    "bundle": "ncc build lib/index.js --license licenses.txt -o dist",
    "lint": "tsc --noEmit",
    "test": "pnpm run compile && node --test",
    "clean": "rimraf lib dist"
  },
  "keywords": [
    "github-action",
    "bundle-size",
    "ci"
  ],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@vercel/ncc": "^0.38.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11 <12"
  },
  "packageManager": "pnpm@11.1.2"
}
