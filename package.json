{
  "name": "bundle-size-action",
  "version": "0.1.0",
  "description": "A GitHub Action to check and report bundle sizes",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "vite build",
    "lint": "oxlint src tests vite.config.ts vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "keywords": [
    "github-action",
    "bundle-size",
    "ci"
  ],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "oxlint": "1.65.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11 <12"
  },
  "packageManager": "pnpm@11.1.2"
}
